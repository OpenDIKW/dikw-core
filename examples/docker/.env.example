# Required — leave blank to force compose to fail-closed until set.
# Generate strong values, e.g. `openssl rand -base64 24` for both.
POSTGRES_PASSWORD=
DIKW_SERVER_TOKEN=

# Provider keys — set the vars your base's dikw.yml names via
# provider.{llm,embedding}_api_key_env (vendor-canonical names). Leave the
# rest blank; add lines for other vendors (DEEPSEEK_API_KEY, MINIMAX_API_KEY,
# …) and mirror them in docker-compose.yml's `environment:` block.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITEE_API_KEY=

# Optional — DEBUG / INFO / WARNING / ERROR / CRITICAL. Default: INFO.
DIKW_LOG_LEVEL=INFO

# Optional — `text` (default) or `json` (one JSON object per record, carries
# trace_id/span_id for log↔trace correlation when telemetry is active).
# DIKW_LOG_FORMAT=json
