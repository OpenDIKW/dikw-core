# Required — leave blank to force compose to fail-closed until set.
# Generate strong values, e.g. `openssl rand -base64 24` for both.
POSTGRES_PASSWORD=
DIKW_SERVER_TOKEN=

# Provider keys — set at least one LLM key plus an embedding key.
# Leave blank for any provider you don't use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DIKW_EMBEDDING_API_KEY=

# Optional — DEBUG / INFO / WARNING / ERROR / CRITICAL. Default: INFO.
DIKW_LOG_LEVEL=INFO

# Optional — `text` (default) or `json` (one JSON object per record, carries
# trace_id/span_id for log↔trace correlation when telemetry is active).
# DIKW_LOG_FORMAT=json
