# Copy to `.env` (gitignored) and fill in real values.
# Loaded automatically by pytest-dotenv for tests; for CLI use
# `uv run --env-file .env dikw …` or `set -a; source .env; set +a`.
#
# This file holds SECRETS ONLY. Non-secret config (endpoint URLs, model
# names, embedding dimensions, batch sizes, display labels) lives in
# `dikw.yml`.
#
# Key env vars are VENDOR-CANONICAL — one `<VENDOR>_API_KEY` per vendor —
# so multiple same-protocol vendors (DeepSeek + MiniMax both speak the
# Anthropic protocol) coexist here without colliding. Which key each base
# uses is chosen IN `dikw.yml`, not here, via:
#   provider.llm_api_key_env:       <name of the LLM key var>
#   provider.embedding_api_key_env: <name of the embedding key var>
# Set only the vars your `dikw.yml` actually references; leave the rest blank.

# ---- LLM keys (pick one per base via provider.llm_api_key_env) ----
ANTHROPIC_API_KEY=        # Anthropic native (api.anthropic.com)
DEEPSEEK_API_KEY=         # DeepSeek (anthropic-compatible: api.deepseek.com/anthropic)
MINIMAX_API_KEY=          # MiniMax (anthropic-compatible: api.minimaxi.com/anthropic)
OPENAI_API_KEY=           # OpenAI / OpenAI-compatible (Azure, Ollama, vLLM, GLM, Gemini-compat, …)

# ---- Embedding keys (pick one per base via provider.embedding_api_key_env) ----
# LLM and embedding can target different vendors — name distinct vars to keep
# their keys separate (e.g. MINIMAX_API_KEY for the LLM + GITEE_API_KEY for embeddings),
# or point both at the same var to share one key. No magic fallback: the embedder
# reads exactly the var named by provider.embedding_api_key_env.
GITEE_API_KEY=            # Gitee AI (bge-m3 / Qwen3-Embedding)
# OPENAI_API_KEY above doubles as the embedding key when you embed via OpenAI.

# ---- optional: Postgres storage-contract tests ----
# Leave unset to skip; set to a pgvector-enabled DSN to include them.
# DIKW_TEST_POSTGRES_DSN=postgresql://dikw:dikw@localhost:5432/dikw_test

# ---- optional: log level ----
# Controls the root logger level for `dikw …` and `dikw serve`.
# Accepts DEBUG / INFO / WARNING / ERROR / CRITICAL. Default INFO.
# DIKW_LOG_LEVEL=INFO

# ---- optional: log format ----
# `text` (default) keeps the human-readable terminal line; `json` emits one JSON
# object per record (machine-readable, carries trace_id/span_id for log↔trace
# correlation when the [otel] extra + telemetry are active).
# DIKW_LOG_FORMAT=json
